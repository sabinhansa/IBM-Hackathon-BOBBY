# ============================================
# BobFlow Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# IBM Bob API Configuration (Server-side only)
# ============================================

# IBM Bob API Key - Required for live workflow analysis
# Get your API key from IBM Bob platform
# CRITICAL: This key is ONLY used server-side and never exposed to the browser
# DO NOT use VITE_ prefix for secrets!
BOB_API_KEY=your_bob_api_key_here

# IBM Bob API Endpoint (optional, defaults to official endpoint)
# Only set this if you're using a custom or enterprise Bob API endpoint
# BOB_API_ENDPOINT=https://api.bob.ibm.com/v1

# ============================================
# Application Configuration (Frontend-safe)
# ============================================

# Enable live API mode (set to 'true' to enable, 'false' for demo-only)
# When false, only sample reports are shown
# When true, live analysis panel appears on workflow pages
VITE_ENABLE_LIVE_MODE=false

# API base URL for frontend (automatically set by Vercel/deployment)
# For local development with Vercel dev server, this defaults to http://localhost:3000
# In production, this uses the same origin as the frontend
# VITE_API_BASE_URL=http://localhost:3000

# ============================================
# Security Notes
# ============================================
# 
# ✅ BOB_API_KEY has NO VITE_ prefix - keeps it server-side only
# ✅ Never commit .env to version control (already in .gitignore)
# ✅ Only use VITE_ prefix for non-sensitive configuration
# ✅ Vercel automatically loads environment variables from dashboard
# ✅ For local development, copy this file to .env and fill in values
#
# ❌ NEVER use VITE_BOB_API_KEY (would expose key to browser!)
# ❌ NEVER commit real API keys to git
