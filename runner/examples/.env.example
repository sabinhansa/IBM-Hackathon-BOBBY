# BobFlow Runner Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file!

# Bob Shell API Key (REQUIRED)
# Get your API key from IBM Bob
BOBSHELL_API_KEY=your-api-key-here

# Target Repository (OPTIONAL)
# Default repository to analyze if not specified via --repo flag
BOBFLOW_TARGET_REPO=/path/to/your/repository

# Output Directory (OPTIONAL)
# Where to save generated reports
